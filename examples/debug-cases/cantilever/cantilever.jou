${height = 1}
${width = 0.5}
${length = 10.0}
${overlap_vol_frac = 0.20}
${h_single = 0.333333}
${h_clamped = 0.333333}
${h_free = 0.333333}
${domain_length_clamped = 6}
${domain_length_free = 6}

create brick x {length} y {height} z {width}
move volume 1 x {length / 2.0} include_merged
move volume 1 z {width / 2.0} include_merged
volume 1 size {h_single}
mesh volume 1
block 1 volume 1
block 1 name "cantilever"
nodeset 1 surface 4
nodeset 1 name "nsx-"
nodeset 2 surface 6
nodeset 2 name "nsx+"
nodeset 3 surface 3
nodeset 3 name "nsy-"
nodeset 4 surface 5
nodeset 4 name "nsy+"
nodeset 5 surface 2
nodeset 5 name "nsz-"
nodeset 6 surface 1
nodeset 6 name "nsz+"
nodeset 7 volume all
nodeset 7 name "nsall"
sideset 1 surface 4
sideset 1 name "ssx-"
sideset 2 surface 6
sideset 2 name "ssx+"
sideset 3 surface 3
sideset 3 name "ssy-"
sideset 4 surface 5
sideset 4 name "ssy+"
sideset 5 surface 2
sideset 5 name "ssz-"
sideset 6 surface 1
sideset 6 name "ssz+"
set large exodus file off
export mesh "cantilever.g" overwrite
delete volume all
compress ids

create brick x {domain_length_clamped} y {height} z {width}
move volume 1 x {domain_length_clamped / 2.0} include_merged
move volume 1 z {width / 2.0} include_merged
volume 1 size {h_clamped}
mesh volume 1
block 1 volume 1
block 1 name "cantilever_clamped"
nodeset 1 surface 4
nodeset 1 name "nsx-"
nodeset 2 surface 6
nodeset 2 name "nsx+"
nodeset 3 surface 3
nodeset 3 name "nsy-"
nodeset 4 surface 5
nodeset 4 name "nsy+"
nodeset 5 surface 2
nodeset 5 name "nsz-"
nodeset 6 surface 1
nodeset 6 name "nsz+"
nodeset 7 volume all
nodeset 7 name "nsall"
sideset 1 surface 4
sideset 1 name "ssx-"
sideset 2 surface 6
sideset 2 name "ssx+"
sideset 3 surface 3
sideset 3 name "ssy-"
sideset 4 surface 5
sideset 4 name "ssy+"
sideset 5 surface 2
sideset 5 name "ssz-"
sideset 6 surface 1
sideset 6 name "ssz+"
set large exodus file off
export mesh "cantilever-clamped.g" overwrite
delete volume all
compress ids

create brick x {domain_length_free} y {height} z {width}
move volume 1 x 4 include_merged
move volume 1 x {domain_length_free / 2.0}
move volume 1 z {width / 2.0} include_merged
volume 1 size {h_free}
mesh volume 1
block 1 volume 1
block 1 name "cantilever_free"
nodeset 1 surface 4
nodeset 1 name "nsx-"
nodeset 2 surface 6
nodeset 2 name "nsx+"
nodeset 3 surface 3
nodeset 3 name "nsy-"
nodeset 4 surface 5
nodeset 4 name "nsy+"
nodeset 5 surface 2
nodeset 5 name "nsz-"
nodeset 6 surface 1
nodeset 6 name "nsz+"
nodeset 7 volume all
nodeset 7 name "nsall"
sideset 1 surface 4
sideset 1 name "ssx-"
sideset 2 surface 6
sideset 2 name "ssx+"
sideset 3 surface 3
sideset 3 name "ssy-"
sideset 4 surface 5
sideset 4 name "ssy+"
sideset 5 surface 2
sideset 5 name "ssz-"
sideset 6 surface 1
sideset 6 name "ssz+"
set large exodus file off
export mesh "cantilever-free.g" overwrite
